{
  "name": "misjuegos-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "pretty": "prettier --write .",
    "ts": "vue-tsc -b --noEmit",
    "db:types": "supabase gen types typescript --local > src/domain/types/database.ts",
    "import:escapes": "tsx --tsconfig tsconfig.scripts.json scripts/importEscapes.ts",
    "import:list-participants": "tsx --tsconfig tsconfig.scripts.json scripts/listImportParticipants.ts",
    "import:list-profiles": "tsx --tsconfig tsconfig.scripts.json scripts/listProfiles.ts",
    "import:board-games": "tsx --tsconfig tsconfig.scripts.json scripts/importBoardGames.ts",
    "import:wishlist": "tsx --tsconfig tsconfig.scripts.json scripts/importWishlist.ts",
    "db:reset-data": "supabase db query --local -f scripts/resetLocalData.sql"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.7.0",
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify-icons/ph": "^1.2.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
