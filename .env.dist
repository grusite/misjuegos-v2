# Supabase local defaults (from `supabase start`). Replace for production.
VITE_SUPABASE_URL=http://127.0.0.1:54321
# Phone on LAN: use http://<LAN_IP>:54321 — see docs/LOCAL_MOBILE_TESTING.md
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_PROJECT_ID=misjuegos-v2

# Google OAuth — required for Supabase Auth (local + prod).
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (local): http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# BoardGameGeek — server-side only (Edge Function secret, NOT VITE_*).
# Local:  cp supabase/functions/.env.dist supabase/functions/.env  → set BGG_TOKEN
# Prod:   supabase secrets set BGG_TOKEN=... --project-ref yyscffeexxtagilftrwo
# See docs/BGG_API.md
